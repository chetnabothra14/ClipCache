# FrameVault Environment Configuration
# Copy this file to .env and update values for your environment

# ─── Owner Authentication ───────────────────────────────────────────────────
# The password required to login as owner/admin
OWNER_PASSWORD=change_me_in_production_!

# ─── JWT Secrets ────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens - change this to a random secure string
SECRET_KEY=your-secret-key-change-this-in-production

# ─── Google OAuth Configuration ─────────────────────────────────────────────
# Optional: Only needed if you want to enable Google Sign-In
# 1. Get your Client ID from Google Cloud Console
# 2. Create OAuth 2.0 Web Application credentials
# 3. Add http://localhost:8000 and http://localhost:3000 to authorized URIs
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# ─── Server Configuration ───────────────────────────────────────────────────
# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend settings
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# ─── Security ──────────────────────────────────────────────────────────────
# Uncomment and set for production
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
